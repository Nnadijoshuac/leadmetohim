{
  "name": "leadmetohim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@leadmetohim/desktop",
    "package": "turbo build --filter=@leadmetohim/desktop && pnpm --filter @leadmetohim/desktop package",
    "seed": "tsx scripts/seed-bible.ts",
    "embeddings": "tsx scripts/generate-embeddings.ts",
    "models": "tsx scripts/download-models.ts",
    "prepare": "pnpm models && pnpm seed && pnpm embeddings",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "tsx": "^4.9.3",
    "rimraf": "^5.0.7",
    "@types/node": "^20.12.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
