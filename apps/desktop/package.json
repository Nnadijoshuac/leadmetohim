{
  "name": "@leadmetohim/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "LeadMeToHim - Scripture Copilot for Windows",
  "author": {
    "name": "LeadMeToHim",
    "email": "godspowerojini8@gmail.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "pnpm build && electron-builder --win",
    "package:dir": "pnpm build && electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "electron-vite typecheck",
    "clean": "rimraf out dist-electron"
  },
  "dependencies": {
    "@leadmetohim/shared-types": "workspace:*",
    "@leadmetohim/database": "workspace:*",
    "@leadmetohim/scripture-engine": "workspace:*",
    "@leadmetohim/vector-search": "workspace:*",
    "@leadmetohim/speech": "workspace:*",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.8",
    "nodejs-whisper": "^0.1.18",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "@vitejs/plugin-react": "^4.3.1",
    "electron-vite": "^2.2.0",
    "framer-motion": "^11.2.10",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.7",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "zustand": "^4.5.4"
  },
  "build": {
    "extends": null,
    "appId": "com.leadmetohim.app",
    "productName": "LeadMeToHim",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../../data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LeadMeToHim"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/nodejs-whisper/**",
      "**/node_modules/@xenova/**"
    ]
  }
}
