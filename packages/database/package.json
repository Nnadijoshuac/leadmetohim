{
  "name": "@leadmetohim/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external better-sqlite3",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external better-sqlite3",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@leadmetohim/shared-types": "workspace:*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "rimraf": "^5.0.7"
  }
}
