{
  "name": "@leadmetohim/speech",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external @xenova/transformers",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external @xenova/transformers",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@leadmetohim/shared-types": "workspace:*",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "rimraf": "^5.0.7",
    "@types/node": "^20.12.12"
  }
}
