{
  "name": "@leadmetohim/speech",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external nodejs-whisper",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external nodejs-whisper",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@leadmetohim/shared-types": "workspace:*",
    "nodejs-whisper": "^0.1.18"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "rimraf": "^5.0.7",
    "@types/node": "^20.12.12"
  }
}
